{
    "$schema": "https://tauri.app/schemas/config-schema.json",
    "productName": "Typst IDE",
    "version": "0.1.0",
    "identifier": "com.typst.ide",
    "build": {

        "frontendDist": "../../frontend/dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Typst IDE",
                "width": 1200,
                "height": 800
            }
        ]
    },
    "plugins": {
        "opener": {
            "requireLiteralLeadingDot": false
        }
    },

    "bundle": {
        "active": true,
        "targets": ["appimage", "nsis"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png"
        ]
    }
}
