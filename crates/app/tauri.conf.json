{
    "$schema": "https://tauri.app/schemas/config-schema.json",
    "identifier": "com.typst.ide",
    "build": {
        "devUrl": "http://localhost:1420",
        "frontendDist": "../../frontend/dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Typst IDE",
                "width": 1200,
                "height": 800
            }
        ]
    },
    "plugins": {
        "opener": {
            "requireLiteralLeadingDot": false
        }
    }
}
