{
  "name": "frontend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run build:css && vite build dist",
    "build:css": "tailwindcss -i src/input.css -o dist/css/output.css --minify",
    "dev:css": "tailwindcss -i src/input.css -o dist/css/output.css --watch",
    "dev": "concurrently \"npm run dev:css\" \"vite dist --port 1420\"",
    "postinstall": "node -e \"require('fs').cpSync('node_modules/monaco-editor/min/vs','dist/vendor/vs',{recursive:true}); require('fs').mkdirSync('dist/css',{recursive:true}); require('fs').copyFileSync('node_modules/material-symbols/material-symbols-outlined.woff2','dist/css/material-symbols-outlined.woff2');\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "material-symbols": "^0.40.2",
    "monaco-editor": "^0.52.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  }
}
